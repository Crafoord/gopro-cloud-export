{
  "name": "gopro-cloud-export",
  "version": "1.0.1",
  "description": "Download all your GoPro Cloud videos with a local web UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/Crafoord/gopro-cloud-export"
  },
  "bin": {
    "gopro-cloud-export": "./bin/gopro-exporter.js"
  },
  "files": [
    "bin",
    "client/dist",
    "server/dist"
  ],
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "prepare": "npm run build"
  }
}
